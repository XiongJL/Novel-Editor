{
  "name": "novel-editor-desktop",
  "version": "0.1.8",
  "type": "module",
  "private": true,
  "main": "dist-electron/main.js",
  "author": "XiongJL",
  "description": "云梦AI小说辅助创作工具",
  "scripts": {
    "dev": "vite",
    "dev:8080": "vite --host 127.0.0.1 --port 8080 --strictPort",
    "dev:local": "vite --host 127.0.0.1 --strictPort",
    "prepare:core": "pnpm --dir ../.. --filter @novel-editor/core run build",
    "predev": "pnpm run prepare:core",
    "copy-prisma": "node scripts/copy-prisma.js",
    "ai:diag": "node scripts/ai-dev-diagnostics.mjs",
    "build": "pnpm run prepare:core && tsc && vite build && electron-builder",
    "build:win:dir": "pnpm run prepare:core && tsc && vite build && electron-builder --win dir && pnpm run fix:win:exe-icon",
    "fix:win:exe-icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-win-exe-icon.ps1 -AppOutDir release/win-unpacked -ProjectDir .",
    "pack:win:prepackaged": "electron-builder --win nsis portable --prepackaged release/win-unpacked",
    "build:win": "pnpm run build:win:dir && pnpm run pack:win:prepackaged",
    "build:mac": "pnpm run prepare:core && tsc && vite build && electron-builder --mac dmg --universal",
    "preview": "vite preview"
  },
  "dependencies": {
    "@novel-editor/core": "workspace:*",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.9",
    "@lexical/history": "^0.40.0",
    "@lexical/mark": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/selection": "^0.40.0",
    "@lexical/utils": "^0.40.0",
    "@types/adm-zip": "^0.5.7",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "clsx": "^2.1.0",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "framer-motion": "^12.29.2",
    "i18next": "^25.8.0",
    "konva": "^8.4.3",
    "lexical": "^0.40.0",
    "lucide-react": "^0.563.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-konva": "^18.2.14",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.1",
    "tailwind-merge": "^2.2.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
